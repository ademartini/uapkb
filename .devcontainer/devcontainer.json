{
  "name": "uapkb",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers-extra/features/pnpm@sha256:694c2b6182435c9e9c06f6071728b087c1181b38c18cecf0defe2ab8c11cddd6": {
      "version": "10"
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=cursor-config-${devcontainerId},target=/home/node/.cursor,type=volume",
    "source=github-cli-config-${devcontainerId},target=/home/node/.config/gh,type=volume",
    "source=node-modules-${devcontainerId},target=${containerWorkspaceFolder}/node_modules,type=volume"
  ],
  "onCreateCommand": "sudo chown -R node:node node_modules",
  "updateContentCommand": "pnpm install --frozen-lockfile --store-dir node_modules/.pnpm-store",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "forwardPorts": [60517, 5432],
  "portsAttributes": {
    "60517": {
      "label": "Next.js dev server",
      "protocol": "http",
      "requireLocalPort": true,
      "onAutoForward": "openPreview"
    },
    "5432": {
      "label": "Postgres (host: docker compose up -d db)"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-playwright.playwright"
      ]
    }
  }
}
